# =============================================================================
# DharmaGPT — production configuration
# Copy to .env and fill in your API keys.
# =============================================================================

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
SARVAM_API_KEY=sk_...
PINECONE_API_KEY=...

# ── Backends ──────────────────────────────────────────────────────────────────
# Production serving policy:
#   LLM_BACKEND=openai          # answer generation
#   EMBEDDING_BACKEND=openai    # production retrieval/index vectors
#   TRANSLATION_BACKEND=sarvam  # corpus creation / Indic translation
#   STT_BACKEND=sarvam          # audio transcription
#
# Staging/local cost-control policy:
#   LLM_BACKEND=ollama
#   LLM_MODEL=qwen2.5:7b
#   EMBEDDING_BACKEND=ollama
#   EMBEDDING_MODEL=nomic-embed-text
#   EMBEDDING_DIMS=768
#   TRANSLATION_BACKEND=indictrans2
#   STT_BACKEND=indicconformer
#
# Validation/evaluation is not run during normal production query requests.
# It is triggered only by evaluation scripts/CI/admin workflows. Use one
# Anthropic judge call per response when validation is enabled.
TRANSLATION_BACKEND=sarvam
EMBEDDING_BACKEND=openai
LLM_BACKEND=openai
RAG_BACKEND=pinecone

# ── Model config ──────────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_MODEL=gpt-4.1-mini
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_URL=http://localhost:11434
INDICTRANS2_MODEL=ai4bharat/indictrans2-indic-en-dist-200M
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMS=3072
PINECONE_INDEX_NAME=dharma-gpt
PINECONE_ENVIRONMENT=us-east-1
STT_BACKEND=sarvam

# ── Evaluation / validation ───────────────────────────────────────────────────
EVALUATION_PRIMARY_BACKEND=anthropic
EVALUATION_PRIMARY_MODEL=claude-sonnet-4-20250514
EVALUATION_PRIMARY_API_KEY=
EVALUATION_PRIMARY_BASE_URL=

# ── RAG tuning ────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.35
MAX_CONTEXT_CHARS=6000

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8081,exp://192.168.1.x:8081
