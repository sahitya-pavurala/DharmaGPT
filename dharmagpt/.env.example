# =============================================================================
# DharmaGPT — beta deployment configuration
# Copy to dharmagpt/.env and fill in real values before starting Docker.
# =============================================================================

# ── API keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
SARVAM_API_KEY=sk_...
PINECONE_API_KEY=...

# ── Admin / beta access ───────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-long-random-admin-key
ADMIN_OPERATOR_API_KEY=change-me-long-random-operator-key
STAGING_API_KEY=change-me-long-random-beta-key

# ── Docker Compose / deployment host ──────────────────────────────────────────
POSTGRES_DB=dharmagpt
POSTGRES_USER=dharmagpt
POSTGRES_PASSWORD=change-me-long-random-postgres-password
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432
HTTP_PORT=80

# Optional: only required when running `docker compose --profile tunnel up -d`.
# Use a Cloudflare Tunnel token that routes the beta hostname to the `nginx`
# service in this compose stack.
CLOUDFLARED_TUNNEL_TOKEN=

# ── Backends ──────────────────────────────────────────────────────────────────
TRANSLATION_BACKEND=sarvam
EMBEDDING_BACKEND=openai
LLM_BACKEND=anthropic
RAG_BACKEND=pinecone
VECTOR_DB_BACKEND=pinecone

# If LLM_BACKEND=ollama inside Docker, use the host gateway address when the
# Ollama daemon runs on the Docker host rather than in the Compose network.
OLLAMA_URL=http://host.docker.internal:11434

# ── Model config ──────────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMS=3072
PINECONE_INDEX_NAME=dharma-gpt
PINECONE_ENVIRONMENT=us-east-1
STT_BACKEND=sarvam

# ── RAG tuning ────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.35
MAX_CONTEXT_CHARS=6000

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=https://beta.dharmagpt.com,http://localhost:8081
