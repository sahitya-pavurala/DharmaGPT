# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (embeddings only) ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Pinecone ───────────────────────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=dharma-gpt
PINECONE_ENVIRONMENT=us-east-1

# ── Sarvam AI ──────────────────────────────────────────────────────────────────
SARVAM_API_KEY=...

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMS=3072

# ── Model ──────────────────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_BACKEND=anthropic
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434
LLM_TIMEOUT_SEC=120

INDICTRANS2_MODEL=ai4bharat/indictrans2-indic-en-dist-200M
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_URL=http://localhost:11434

# ── Manual translation review API ────────────────────────
MANUAL_TRANSLATION_API_KEY=
MANUAL_TRANSLATION_DATASET_ROOT=knowledge/processed
MANUAL_TRANSLATION_AUDIT_LOG=knowledge/audit/manual_translation_audit.jsonl
MANUAL_TRANSLATION_ALLOWED_DATASETS=

# ── RAG tuning ─────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.35
MAX_CONTEXT_CHARS=6000

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8081,exp://192.168.1.x:8081
