{
  "expo": {
    "name": "DharmaGPT",
    "slug": "dharmagpt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dharmagpt",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B00"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dharmagpt.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "DharmaGPT uses the microphone for voice queries.",
        "NSSpeechRecognitionUsageDescription": "DharmaGPT uses speech recognition for voice queries."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B00"
      },
      "package": "com.dharmagpt.app",
      "versionCode": 1,
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF6B00"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
