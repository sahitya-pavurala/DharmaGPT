# =============================================================================
# DharmaGPT — beta/staging local-provider configuration
# Copy values into dharmagpt/.env on the beta server.
# =============================================================================

# App
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8081,http://localhost:3000,null

# Admin/API access
ADMIN_API_KEY=
ADMIN_OPERATOR_API_KEY=
STAGING_API_KEY=

# Query serving: local model for beta cost control
LLM_BACKEND=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_URL=http://localhost:11434
LLM_TIMEOUT_SEC=120

# Retrieval/vector store
RAG_BACKEND=pinecone
VECTOR_DB_BACKEND=pinecone
PINECONE_INDEX_NAME=dharma-gpt
PINECONE_ENVIRONMENT=us-east-1
PINECONE_API_KEY=

# Embeddings: local Ollama for beta ingestion/query embeddings
EMBEDDING_BACKEND=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMS=768

# Corpus/audio creation: local Indic models, no Sarvam calls
STT_BACKEND=indicconformer
TRANSLATION_BACKEND=indictrans2
INDICTRANS2_MODEL=ai4bharat/indictrans2-indic-en-dist-200M

# Evaluation is explicit only; normal query serving does not validate responses.
EVALUATION_PRIMARY_BACKEND=anthropic
EVALUATION_PRIMARY_MODEL=claude-sonnet-4-20250514
EVALUATION_PRIMARY_API_KEY=
EVALUATION_PRIMARY_BASE_URL=

# Optional production-provider keys. Leave blank for local beta corpus runs.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SARVAM_API_KEY=
